---
export interface Props {
	/** 白色词条 — 基础属性（DAMAGE, CRITICAL DAMAGE 等） */
	w?: string[];
	/** 红色词条 — 特殊修饰（BOSS DAMAGE, COOLDOWN SECONDS 等） */
	r?: string[];
	/** 黄色词条 — 技能等级、物品品质（COOLDOWN SKILL LV, ITEM QUALITY 等） */
	y?: string[];
	/** 蓝色词条 — 物品能力、额外加成（CAN BE EQUIPPED TO, ATTACK SPEED 等） */
	b?: string[];
}

const { w = [], r = [], y = [], b = [] } = Astro.props;

function escapeHtml(str: string): string {
	return str
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/"/g, "&quot;");
}

/**
 * 解析 w/r 词条中的数值和升级箭头，自动着色。
 * - 升级箭头 `->`：基础值绿色(eq-g)，升级值黄色(eq-y)
 * - 值优先行（如 +1 ARROW）：值绿色
 * - 标准行（NAME VALUE SUFFIX）：值绿色
 * - 无匹配：原样输出
 */
function parseLine(line: string, color: "w" | "r"): string {
	// Step 1: 升级箭头模式 "NAME VALUE1 -> VALUE2 SUFFIX"
	const upgradeRe =
		/^(.+?)\s+([+-]?\d+(?:\.\d+)?%?)\s*->\s*([+-]?\d+(?:\.\d+)?%?)(.*)$/;
	const upMatch = line.match(upgradeRe);
	if (upMatch) {
		const [, name, fromVal, toVal, suffix] = upMatch;
		// 红词条中的 -> 需显式设为白色
		const arrow =
			color === "r"
				? ` <span class="eq-w">-&gt;</span> `
				: " -&gt; ";
		const suffixText = suffix ? ` ${escapeHtml(suffix.trimStart())}` : "";
		return `${escapeHtml(name)} <span class="eq-g">${escapeHtml(fromVal)}</span>${arrow}<span class="eq-y">${escapeHtml(toVal)}</span>${suffixText}`;
	}

	// Step 2: 值优先 + 升级箭头 "+VALUE1 -> VALUE2 SUFFIX"
	// 例如 "+1.9 -> 2.3 SEC SUMMONED TIME"
	const vfUpgradeRe =
		/^([+-]?\d+(?:\.\d+)?%?)\s*->\s*([+-]?\d+(?:\.\d+)?%?)(.*)$/;
	const vfUpMatch = line.match(vfUpgradeRe);
	if (vfUpMatch) {
		const [, fromVal, toVal, suffix] = vfUpMatch;
		const arrow =
			color === "r"
				? ` <span class="eq-w">-&gt;</span> `
				: " -&gt; ";
		const suffixText = suffix ? ` ${escapeHtml(suffix.trimStart())}` : "";
		return `<span class="eq-g">${escapeHtml(fromVal)}</span>${arrow}<span class="eq-y">${escapeHtml(toVal)}</span>${suffixText}`;
	}

	// Step 3: 值优先模式（无箭头）"+VALUE NAME (SUFFIX)"
	const vfRe = /^([+-]?\d+(?:\.\d+)?%?)\s+(.+)$/;
	const vfMatch = line.match(vfRe);
	if (vfMatch) {
		return `<span class="eq-g">${escapeHtml(vfMatch[1])}</span> ${escapeHtml(vfMatch[2])}`;
	}

	// Step 4: 标准模式 — 找到第一个 +/- 数值并着色
	const valueRe = /[+-]?\d+(?:\.\d+)?%?/;
	const valMatch = line.match(valueRe);
	if (valMatch) {
		const value = valMatch[0];
		// 只处理以 +/- 开头或包含百分号/明显是数值的情况
		const idx = valMatch.index!;
		const prefix = line.slice(0, idx).trimEnd();
		const suffix = line.slice(idx + value.length).trimStart();

		const escapedPrefix = prefix ? escapeHtml(prefix) : "";
		const escapedSuffix = suffix ? ` ${escapeHtml(suffix)}` : "";
		return `${escapedPrefix} <span class="eq-g">${escapeHtml(value)}</span>${escapedSuffix}`.trimStart();
	}

	// Step 5: 无匹配，原样输出
	return escapeHtml(line);
}

function buildSection(
	lines: string[],
	color: "w" | "r" | "y" | "b",
): string {
	if (lines.length === 0) return "";
	const parsed =
		color === "w" || color === "r"
			? lines.map((l) => parseLine(l, color)).join("<br/>")
			: lines.map(escapeHtml).join("<br/>");
	return `<span class="eq-${color}">${parsed}</span>`;
}

const sections = [
	buildSection(w, "w"),
	buildSection(r, "r"),
	buildSection(y, "y"),
	buildSection(b, "b"),
].filter(Boolean);

const html =
	sections.length > 0
		? `<span class="eq-bg">${sections.join("<br/>")}</span>`
		: "";
---

{html && <span set:html={html} />}

<style is:global>
	@font-face {
		font-family: "Fusion Pixel";
		src: url("/assets/fonts/fusion-pixel-10px-monospaced-zh_hans.otf") format("opentype");
		font-display: swap;
	}

	.eq-bg {
		background: #62594a;
		display: inline-block;
		padding: 2px 6px;
		font-family: "Fusion Pixel", monospace;
		/* font-size: 16px; */
	}
	.eq-w { color: #f9f7f6; }
	.eq-r { color: #d53d45; }
	.eq-y { color: #ecd133; }
	.eq-b { color: #58a6ff; }
	.eq-g { color: #a4c35a; }
</style>
